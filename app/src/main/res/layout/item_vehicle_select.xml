<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardVehicle"
    android:layout_width="150dp"
    android:layout_height="120dp"
    android:layout_margin="8dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:strokeColor="#121921"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="8dp">

        <ImageView
            android:id="@+id/ivVehicleImage"
            android:layout_width="80dp"
            android:layout_height="50dp"
            android:scaleType="centerInside"
            android:src="@drawable/logo_travel_ra" />

        <TextView
            android:id="@+id/tvVehicleName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Vehicle Name"
            android:textColor="#121921"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPaxCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1-4 passengers"
            android:textSize="12sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>